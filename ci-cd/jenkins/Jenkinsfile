pipeline {
    agent any

    environment {
        IMAGE_NAME = "enterprise-task-platform"
        IMAGE_TAG = "latest"
        CONTAINER_NAME = "task-platform"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout Code') {
            steps {
                cleanWs()
                git branch: 'main',
                    url: 'https://github.com/fred2030/enterprise-task-platform.git'
            }
        }

        stage('Build Application') {
            steps {
                sh '''
                cd app
                chmod +x mvnw
                ./mvnw clean package -DskipTests
                '''
            }
        }

        stage('Unit Tests (Optional Gate)') {
            steps {
                sh '''
                cd app
                ./mvnw test
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker --version
                docker build -t $IMAGE_NAME:$IMAGE_TAG -f app/Dockerfile app
                '''
            }
        }

        stage('Stop Old Container') {
            steps {
                sh '''
                docker stop $CONTAINER_NAME || true
                docker rm $CONTAINER_NAME || true
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d \
                -p 8080:8080 \
                --name $CONTAINER_NAME \
                $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                sleep 10
                curl -f http://localhost:8080 || exit 1
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deployment successful"
        }

        failure {
            echo "❌ Pipeline failed"
        }

        always {
            cleanWs()
        }
    }
}
