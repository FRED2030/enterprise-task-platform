pipeline {
    agent {
        docker {
            image 'docker:latest'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        IMAGE_NAME = "enterprise-task-platform"
        IMAGE_TAG = "latest"
    }

    stages {

        stage('Checkout Code') {
            steps {
                cleanWs()
                git branch: 'main',
                    url: 'https://github.com/fred2030/enterprise-task-platform.git'
            }
        }

        stage('Build Application') {
            steps {
                sh '''
                cd app
                chmod +x mvnw
                ./mvnw clean package -DskipTests
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME:$IMAGE_TAG -f docker/application/Dockerfile .
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker stop task-platform || true
                docker rm task-platform || true
                docker run -d -p 8080:8080 --name task-platform $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }
    }
}
